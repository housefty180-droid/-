// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: items
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - UID of the owner
//   - name: string (required, max 100) - Name of the item
//   - category: string (required, enum: frozen, refrigerated, room_temp)
//   - expiryDate: timestamp (optional) - Expiration date
//   - addedDate: timestamp (required) - Date added
//   - status: string (required, enum: active, consumed, discarded)
//   - quantity: number (optional) - Amount
//   - unit: string (optional, max 50) - Unit of measurement
//   - lastModified: timestamp (optional) - Last update time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isAuthenticated() && request.auth.uid == userId) || 
             (!isAuthenticated() && userId == 'guest_user_default');
    }

    function isDocOwner() {
      return isOwner(resource.data.userId);
    }

    function isValidItem(data) {
      return data.keys().hasAll(['userId', 'name', 'category', 'status']) &&
             data.userId is string &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category in ['frozen', 'refrigerated', 'room_temp'] &&
             data.status in ['active', 'consumed', 'discarded'] &&
             (!('quantity' in data) || data.quantity is number) &&
             (!('unit' in data) || (data.unit is string && data.unit.size() <= 50)) &&
             (!('expiryDate' in data) || data.expiryDate is timestamp || data.expiryDate == null);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "housefty180@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /items/{itemId} {
      // Allow reading if the user is the owner (including guest)
      allow read: if isDocOwner() || isAdmin();
      
      // Allow creating if the user sets themselves as the owner
      allow create: if isValidItem(request.resource.data) && 
                    (isOwner(request.resource.data.userId) || isAdmin());
      
      // Allow updating if the user is the owner and the data remains valid
      allow update: if isValidItem(request.resource.data) && 
                    (isDocOwner() || isAdmin()) &&
                    request.resource.data.userId == resource.data.userId; // userId is immutable
                    
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }
  }
}
