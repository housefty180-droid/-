{
  "entities": {
    "FridgeItem": {
      "title": "Fridge Item",
      "description": "An item stored in the refrigerator or pantry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The UID of the owner." },
        "name": { "type": "string", "description": "Name of the item." },
        "category": { "type": "string", "enum": ["frozen", "refrigerated", "room_temp"] },
        "expiryDate": { "type": "string", "format": "date-time", "description": "When the item expires." },
        "addedDate": { "type": "string", "format": "date-time", "description": "When the item was added." },
        "status": { "type": "string", "enum": ["active", "consumed", "discarded"] },
        "quantity": { "type": "number", "description": "Amount of the item." },
        "unit": { "type": "string", "description": "Unit of measurement." },
        "lastModified": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["userId", "name", "category", "status"]
    }
  },
  "firestore": {
    "/items/{itemId}": {
      "schema": "FridgeItem",
      "description": "Collection of all food items across all users."
    }
  }
}
